{
  "productName": "VoxelProxy",
  "version": "6.2.6",
  "identifier": "com.kauri-off.voxelproxy",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "VoxelProxy",
        "width": 960,
        "height": 640,
        "minWidth": 760,
        "minHeight": 550,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico"],
    "resources": {
      "windivert/WinDivert.dll": "WinDivert.dll",
      "windivert/WinDivert64.sys": "WinDivert64.sys"
    },
    "windows": {
      "wix": {
        "language": "ru-RU",
        "upgradeCode": "89f4c226-20a4-4ba9-b708-fac6123339a7",
        "fragmentPaths": ["common.wxs"],
        "componentRefs": ["FirewallException"]
      }
    },
    "licenseFile": "assets/license.rtf"
  }
}
